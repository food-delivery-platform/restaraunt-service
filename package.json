{
  "name": "menu-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "npm run typecheck && npm run lint && npm run format:check",
    "dev": "tsx src/server.ts",
    "format:check": "prettier --check \"src/**/*.ts\" \"package*.json\" \"tsconfig.json\" \".prettierrc.json\" \"eslint.config.mjs\" \".github/**/*.yml\"",
    "lint": "eslint src --max-warnings=0",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.1085.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "knex": "^3.1.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.7",
    "eslint": "^9.30.1",
    "prettier": "^3.6.2",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "zod": "^3.25.67"
  }
}
