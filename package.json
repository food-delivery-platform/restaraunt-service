{
  "name": "menu-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "npm run typecheck && npm run lint && npm run format:check",
    "format:check": "prettier --check \"src/**/*.ts\" \"package*.json\" \"tsconfig.json\" \".prettierrc.json\" \"eslint.config.mjs\" \".github/**/*.yml\"",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "eslint": "^9.30.1",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "zod": "^3.25.67"
  }
}
